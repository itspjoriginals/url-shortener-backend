<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>GetHire Links</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    body {
      background: linear-gradient(135deg, #0f172a, #1e293b);
      color: #e2e8f0;
      min-height: 100vh;
    }

    .container {
      max-width: 1100px;
      margin: auto;
      padding: 2rem;
    }

    /* 🔥 Header */
    header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    h1 {
      font-size: 2.8rem;
      font-weight: 700;
      background: linear-gradient(to right, #38bdf8, #6366f1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .subtitle {
      color: #94a3b8;
      margin-top: 0.5rem;
    }

    /* 🔥 Card */
    .card {
      background: rgba(255,255,255,0.05);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 2rem;
      margin-bottom: 2rem;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    /* 🔥 Input Section */
    .form-group {
      display: flex;
      gap: 10px;
    }

    input {
      flex: 1;
      padding: 0.9rem;
      border-radius: 10px;
      border: none;
      outline: none;
      font-size: 1rem;
    }

    button {
      padding: 0.9rem 1.4rem;
      border-radius: 10px;
      border: none;
      background: linear-gradient(to right, #38bdf8, #6366f1);
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: 0.3s ease;
    }

    button:hover {
      transform: scale(1.05);
    }

    /* 🔥 Result */
    .result {
      margin-top: 1rem;
      padding: 1rem;
      background: rgba(56,189,248,0.1);
      border-radius: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .result a {
      color: #38bdf8;
      text-decoration: none;
      font-weight: 500;
    }

    .copy-btn {
      background: #22c55e;
    }

    /* 🔥 Table */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }

    th {
      text-align: left;
      padding: 12px;
      color: #94a3b8;
      font-size: 0.85rem;
      text-transform: uppercase;
    }

    td {
      padding: 14px 12px;
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    tr:hover {
      background: rgba(255,255,255,0.05);
    }

    .clicks {
      font-weight: bold;
      color: #22c55e;
    }

    .short-link {
      color: #38bdf8;
      text-decoration: none;
    }

  </style>
</head>

<body>

<div class="container">

  <!-- 🔥 HERO -->
  <header>
    <h1>🚀 Link Shortener</h1>
    <p class="subtitle">Create, manage & track your links like a pro</p>
  </header>

  <!-- 🔥 CREATE LINK -->
  <div class="card">
    <form method="post" action="/url">
      <div class="form-group">
        <input type="text" name="url" placeholder="Paste your long URL here..." required />
        <button type="submit">Shorten</button>
      </div>
    </form>

    <% if (locals.id) { %>
      <div class="result">
        <a id="shortUrl" href="http://localhost:8000/url/<%= id %>" target="_blank">
          http://localhost:8000/url/<%= id %>
        </a>
        <button class="copy-btn" onclick="copyLink()">Copy</button>
      </div>
    <% } %>
  </div>

  <!-- 🔥 TABLE -->
  <% if (locals.urls && urls.length > 0) { %>
  <div class="card">
    <h2>Your Links</h2>

    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Short Link</th>
          <th>Original URL</th>
          <th>Clicks</th>
        </tr>
      </thead>

      <tbody>
        <% urls.forEach((url, index) => { %>
          <tr>
            <td><%= index + 1 %></td>

            <td>
              <a class="short-link" href="/url/<%= url.shortId %>" target="_blank">
                <%= url.shortId %>
              </a>
            </td>

            <td style="font-size: 0.85rem; color: #94a3b8;">
              <%= url.redirectURL %>
            </td>

            <td class="clicks">
              <%= url.visitHistory.length %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

</div>

<!-- 🔥 Copy Script -->
<script>
  function copyLink() {
    const text = document.getElementById("shortUrl").innerText;
    navigator.clipboard.writeText(text);
    alert("Copied to clipboard!");
  }
</script>

</body>
</html>